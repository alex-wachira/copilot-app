# Copy this file to .env.local and fill in your Supabase credentials
# Get these from https://supabase.com → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# PredictHQ — event demand forecasting
# Get a free key at https://predicthq.com
VITE_PREDICTHQ_TOKEN=your-predicthq-token-here

# OpenWeatherMap — weather signals
# Get a free key at https://openweathermap.org/api
VITE_OPENWEATHER_KEY=your-openweather-key-here

# Anthropic — powers the Co-Pilot AI assistant
# Get your key at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
